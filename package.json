{
  "name": "prpack",
  "version": "0.1.0",
  "description": "Local-first PR handoff pack generator for branchbrief, qualitygate, and git metadata.",
  "type": "module",
  "bin": {
    "prpack": "./dist/src/cli.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/fix-bin-mode.mjs",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/test/*.test.js",
    "smoke": "npm run build && bash scripts/smoke.sh",
    "release:check": "npm run check && npm test && npm run smoke && npm pack --dry-run"
  },
  "keywords": [
    "pull-request",
    "pr",
    "cli",
    "code-review",
    "markdown",
    "branchbrief",
    "qualitygate"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/prpack.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/prpack/issues"
  },
  "homepage": "https://github.com/rogerchappel/prpack#readme",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
